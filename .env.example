# ── 服务器 ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Anthropic Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
AI_MODEL=claude-opus-4-6
AI_BATCH_SIZE=20

# ── DeepSeek ─────────────────────────────────────────────────────────────────
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI 兼容接口（支持 Ollama / LM Studio / Groq 等）─────────────────────
OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=http://localhost:11434/v1    # Ollama 示例
# OPENAI_BASE_URL=http://localhost:1234/v1     # LM Studio 示例
OPENAI_MODEL=gpt-4o-mini

# ── 词典 API ─────────────────────────────────────────────────────────────────
# Merriam-Webster: https://dictionaryapi.com/
MERRIAM_WEBSTER_KEY=your_mw_key_here
# Oxford: https://developer.oxforddictionaries.com/
OXFORD_APP_ID=your_oxford_app_id
OXFORD_APP_KEY=your_oxford_app_key
# 有道智云: https://ai.youdao.com/
YOUDAO_APP_KEY=your_youdao_app_key
YOUDAO_APP_SECRET=your_youdao_app_secret
# ECDICT 离线词典: https://github.com/skywind3000/ECDICT (下载 ecdict.csv)
# ECDICT_PATH=data/ecdict.csv

# ── 词汇生成提供商 ─────────────────────────────────────────────────────────
# 可选: claude | deepseek | openai | free_dict | merriam_webster | youdao | ecdict
VOCAB_PROVIDER=claude

# ── 计分权重 ──────────────────────────────────────────────────────────────────
WEIGHT_BODY=1.0
WEIGHT_STEM=1.5
WEIGHT_OPTION=3.0

# ── OCR ──────────────────────────────────────────────────────────────────────
# Tesseract 路径（Windows 需要，Linux/macOS 通常在 PATH 中）
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
OCR_LANGUAGE=eng

# ── 文本清洗（用 AI 自动修正 OCR 错误）───────────────────────────────────────
# 可选: none | claude | deepseek | openai
TEXT_CLEANER_BACKEND=none

# ── 存储路径 ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=data/uploads
RESULTS_DIR=data/exports
OCR_CACHE_DIR=data/ocr_cache
FILE_STORE_DIR=data/files

# ── 数据库 ────────────────────────────────────────────────────────────────────
DB_PATH=app.db
