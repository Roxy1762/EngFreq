# ── 服务器 ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Anthropic Claude ─────────────────────────────────────────────────────────
# 申请地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here
# 可选模型: claude-opus-4-7 (最强), claude-sonnet-4-6 (均衡), claude-haiku-4-5 (快速)
AI_MODEL=claude-opus-4-7
AI_BATCH_SIZE=25
# 开启 Prompt Caching：长 system 提示在一次分析中会被缓存复用，降低成本与延迟
AI_PROMPT_CACHING=true

# ── DeepSeek ─────────────────────────────────────────────────────────────────
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI 兼容接口（支持 Ollama / LM Studio / Groq 等）─────────────────────
OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=http://localhost:11434/v1    # Ollama 示例
# OPENAI_BASE_URL=http://localhost:1234/v1     # LM Studio 示例
OPENAI_MODEL=gpt-4o-mini

# ── 词典 API ─────────────────────────────────────────────────────────────────
# Merriam-Webster: https://dictionaryapi.com/
MERRIAM_WEBSTER_KEY=your_mw_key_here
# Oxford: https://developer.oxforddictionaries.com/
OXFORD_APP_ID=your_oxford_app_id
OXFORD_APP_KEY=your_oxford_app_key
# 有道智云: https://ai.youdao.com/
YOUDAO_APP_KEY=your_youdao_app_key
YOUDAO_APP_SECRET=your_youdao_app_secret
# ECDICT 离线词典: https://github.com/skywind3000/ECDICT
# ECDICT_PATH=data/ecdict.csv

# ── 词汇生成提供商 ─────────────────────────────────────────────────────────
# 可选: claude | deepseek | openai | free_dict | merriam_webster | youdao | ecdict
VOCAB_PROVIDER=claude

# ── Prompt 领域 ──────────────────────────────────────────────────────────────
# 可选: gaokao (高考) | ielts | cet (四六级)
PROMPT_DOMAIN=gaokao
PROMPT_VERSION=v2

# ── LLM 重试策略 ─────────────────────────────────────────────────────────────
# 全部 LLM 调用都会使用指数回退的自动重试（429 / 网络抖动 / 5xx 等瞬时错误）
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_INITIAL_DELAY=1.5
LLM_RETRY_MAX_DELAY=20.0

# ── 计分权重 ──────────────────────────────────────────────────────────────────
WEIGHT_BODY=1.0
WEIGHT_STEM=1.5
WEIGHT_OPTION=3.0

# ── OCR ──────────────────────────────────────────────────────────────────────
# Tesseract 路径（Windows 需要，Linux/macOS 通常在 PATH 中）
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
OCR_LANGUAGE=eng

# ── 文本清洗（用 AI 自动修正 OCR 错误）───────────────────────────────────────
# 可选: none | claude | deepseek | openai
TEXT_CLEANER_BACKEND=none

# ── 上传限制 ─────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── 存储路径 ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=data/uploads
RESULTS_DIR=data/exports
OCR_CACHE_DIR=data/ocr_cache
FILE_STORE_DIR=data/files

# ── 数据库 ────────────────────────────────────────────────────────────────────
DB_PATH=app.db
